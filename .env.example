# ctxbridge configuration — copy to .env (or just export these) as needed.
# Everything works with zero config; these only upgrade behavior.

# Where the local SQLite memory lives. Default: ~/.ctxbridge/ctxbridge.db
# CTXBRIDGE_DB=/absolute/path/to/ctxbridge.db

# Embedding provider: "local" (default, zero-config) or "openai".
# CTXBRIDGE_EMBEDDER=local

# Only needed if CTXBRIDGE_EMBEDDER=openai. Enables higher-quality semantic search.
# OPENAI_API_KEY=sk-...
# CTXBRIDGE_OPENAI_EMBED_MODEL=text-embedding-3-small

# Tag where memories come from / default scope (set per-CLI in that CLI's MCP config).
# CTXBRIDGE_SOURCE=mcp
# CTXBRIDGE_PROJECT=global

# ---- Phase 2 (cloud sync, not yet implemented) ----
# CTXBRIDGE_SYNC_URL=https://your-sync-server.example.com
# CTXBRIDGE_SYNC_TOKEN=...
